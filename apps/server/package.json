    "@openproxy/schema": "workspace:*",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.9",
    "@sentry/bun": "^10.59.0",
    "better-auth": "^1.6.20",
    "decimal.js": "^10.6.0",
    "drizzle-orm": "0.45.2",
    "elysia": "^1.4.29",
