# Example environment variables for docker-compose
# Database
DATABASE_URL=postgresql://postgres:postgres@postgresql:5432/openproxy

# Auth
BETTER_AUTH_SECRET=your-secret
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5173,http://aiproxy.shop,http://www.aiproxy.shop
BETTER_AUTH_URL=http://localhost:5173/api
APP_DOMAIN=
CLIENT_ORIGIN=
IS_OSS=true
CRON_SECRET=

# Server
PORT=3888

# Email
RESEND_API_KEY=
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
AXIOM_DATASET=
AXIOM_TOKEN=

# OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# RSA
RSA_PRIVATE_KEY=
RSA_PUBLIC_KEY=

# Monitoring
SENTRY_DSN=

# Alibaba Cloud
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
ALI_CAPTCHA_API_KEY=

# ZPayZ
ZPAYZ_CID=
ZPAYZ_PID=
ZPAYZ_PAY_KEY=
ZPAYZ_GATEWAY=https://zpayz.cn/submit.php

# API
API_RATE_LIMIT_PER_MINUTE=
DB_MAX_CONNECTIONS=

REDIS_URL=redis://redis:6379
