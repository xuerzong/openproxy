# Example environment variables for docker-compose
# Database
DATABASE_URL=postgresql://postgres:postgres@postgresql:5432/openproxy
REDIS_URL=redis://redis:6379

# Auth
BETTER_AUTH_SECRET=your-secret

# When APP_DOMAIN is set, BETTER_AUTH_URL should usually be set to
# https://app.${APP_DOMAIN} to match the tenant app origin.
BETTER_AUTH_URL=

# APP_DOMAIN is the apex domain (e.g. example.com). It controls trusted
# origins for *.APP_DOMAIN and the better-auth cross-subdomain cookie
# domain (.APP_DOMAIN), so *.APP_DOMAIN subdomains share one session.
APP_DOMAIN=

# CLIENT_ORIGIN is the public origin of the tenant web app (scheme + host,
# no trailing slash, e.g. https://app.example.com). It is used to build
# payment notify/return URLs and email verification links. Defaults to
# https://app.${APP_DOMAIN} in production and http://localhost:5173 in dev.
CLIENT_ORIGIN=
## Comma-separated emails promoted to admin immediately after signup.
## Example: ADMIN_EMAILS=owner@example.com,ops@example.com
ADMIN_EMAILS=

IS_OSS=true
CRON_SECRET=

# Web runtime config
UMAMI_WEBSITE_ID=

# Email
RESEND_API_KEY=
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# RSA
RSA_PRIVATE_KEY=
RSA_PUBLIC_KEY=

# Monitoring
SENTRY_DSN=

# Alibaba Cloud
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
ALI_CAPTCHA_API_KEY=

# ZPayZ
ZPAYZ_CID=
ZPAYZ_PID=
ZPAYZ_PAY_KEY=
ZPAYZ_GATEWAY=https://zpayz.cn/submit.php

# API
API_RATE_LIMIT_PER_MINUTE=
DB_MAX_CONNECTIONS=
