{
  "name": "openproxy",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "website"
  ],
  "dependencies": {
    "turbo": "^2.9.6"
  },
  "scripts": {
    "dev": "turbo run dev --filter=server & turbo run dev:admin --filter=web & turbo run dev:tenant --filter=web & wait",
    "lint": "turbo run lint --filter=server --filter=web",
    "lint:server": "turbo run lint --filter=server",
    "lint:web": "turbo run lint --filter=web"
  },
  "packageManager": "bun@1.3.5"
}
